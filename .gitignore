# Terraform working directory
.terraform/

# Terraform state files
*.tfstate
*.tfstate.*

# Variable files (may contain secrets)
terraform.tfvars
*.auto.tfvars

# SSH keys
*.pem
*.key

# Crash logs
crash.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Terraform CLI config
.terraformrc
terraform.rc
